# Supabase — obtén estos valores en https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# URL pública del sitio (sin barra final).
# En Vercel (producción): https://tu-dominio.vercel.app
# En local: http://localhost:3000
# Si no se define, en Vercel se usa VERCEL_URL automáticamente.
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# WhatsApp del administrador (con código de país, sin espacios)
# Si no se define, se usa el valor por defecto del código.
NEXT_PUBLIC_ADMIN_WHATSAPP=+56951010473
